{
    "name": "courier-web-root",
    "version": "1.0.0",
    "description": "Root orchestration for courier_web project",
    "scripts": {
        "install:backend": "cd backend && npm install",
        "install:frontend": "cd frontend && npm install",
        "install:all": "npm run install:backend && npm run install:frontend",
        "build:backend": "cd backend && npm install && npm run build",
        "build:frontend": "cd frontend && npm install && npx next build",
        "build": "echo 'Please use build:backend or build:frontend'",
        "dev:backend": "cd backend && npm run start:dev",
        "dev:frontend": "cd frontend && npm run dev",
        "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"bgBlue.bold,bgGreen.bold\" \"npm run dev:backend\" \"npm run dev:frontend\"",
        "start:backend": "cd backend && npm run start:prod",
        "start:frontend": "cd frontend && npm run start",
        "start": "concurrently -n \"BACKEND,FRONTEND\" -c \"bgBlue.bold,bgGreen.bold\" \"npm run start:backend\" \"npm run start:frontend\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}